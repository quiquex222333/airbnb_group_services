$version: "2"

namespace airbnbclone.common.headers

@documentation("Headers used for distributed tracing and request tracking.")
@mixin
structure TraceHeaders {
    @required
    @httpHeader("X-Request-Id")
    @documentation("Unique identifier for the original incoming request. Generated by the API Gateway if absent.")
    requestId: String

    @required
    @httpHeader("X-Correlation-Id")
    @documentation("Identifier propagated across microservices for distributed tracing.")
    correlationId: String
}

@documentation("Headers used for JSON content negotiation.")
@mixin
structure JsonHeaders {
    @httpHeader("Content-Type")
    @documentation("Media type of the request body. Use application/json for requests with body.")
    contentType: String

    @httpHeader("Accept")
    @documentation("Expected media type of the response. Use application/json.")
    accept: String
}
